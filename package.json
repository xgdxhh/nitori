{
  "name": "nitori",
  "version": "0.1.0",
  "description": "Inbox-first Nitori runtime",
  "type": "module",
  "main": "dist/main.mjs",
  "bin": {
    "nitori": "./dist/main.mjs"
  },
  "files": [
    "dist"
  ],
  "workspaces": ["packages/*"],
  "scripts": {
    "generate:templates": "bun run scripts/generate-builtin-templates.ts",
    "dev": "bun run src/main.ts",
    "build": "bun build src/main.ts --outfile dist/main.mjs --target node",
    "compile": "bun build --compile src/main.ts --outfile bin/nitori",
    "typecheck": "tsgo --noEmit",
    "lint": "oxlint src",
    "lint:fix": "oxlint src --fix --fix-suggestions",
    "check": "bun typecheck && bun lint"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "bun@1.3.10",
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.64",
    "@ai-sdk/google": "^3.0.53",
    "@ai-sdk/mcp": "^1.0.35",
    "@ai-sdk/openai": "^3.0.48",
    "@ai-sdk/openai-compatible": "^2.0.37",
    "@chat-adapter/telegram": "^4.23.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ai": "^6.0.141",
    "croner": "^9.1.0",
    "dayjs": "^1.11.19",
    "grammy": "^1.41.1",
    "valibot": "^1.2.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "@types/node": "^25.3.3",
    "@typescript/native-preview": "^7.0.0-dev.20260323.1",
    "oxlint": "^1.51.0"
  }
}
